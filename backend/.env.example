# Copy to .env and adjust for your environment.
# A secret used to sign session tokens. If unset, a random one is generated
# at process start (fine for a demo, but sessions won't survive a restart).
JWT_SECRET_KEY=change-me-to-a-long-random-string

# SQLite by default; swap for a Postgres URL in production, e.g.
# postgresql://user:password@localhost:5432/carbon_app
DATABASE_URL=sqlite:///./carbon_app.db

# Comma-separated list of origins allowed to call this API from a browser.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
